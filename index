<!DOCTYPE html>
<html>
<head>
    <title>Print Page</title>
    <style>
        body { font-family: Arial; padding: 20px; }
        .box { border: 1px solid #000; padding: 10px; margin-bottom: 10px; }
        @media print { button { display: none; } }
    </style>
</head>

<body>

<h2>Print View</h2>

<div class="box">
    <div><strong>ID:</strong> <span id="id"></span></div>
    <div><strong>Name:</strong> <span id="name"></span></div>
    <div><strong>Date:</strong> <span id="date"></span></div>
</div>

<button onclick="window.print()">Print</button>

<script>
const params = new URLSearchParams(window.location.search);

document.getElementById("id").innerText = params.get("id") || "";
document.getElementById("name").innerText = params.get("name") || "";
document.getElementById("date").innerText = params.get("date") || "";
</script>

</body>
</html>
